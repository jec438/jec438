/**
 * Calculates the average premium for a fleet quote.
 *
 * @param {number} inputFleetSize  - Number of vehicles in the fleet.
 * @param {boolean} [bustCache]    - Pass true to force a refresh of cached sheet data.
 * @returns {number} Average premium across all approved/matched VINs.
 */

  // trigger absorbs any extra args passed from the sheet to force recalc
  // no other changes needed
  function premium_fleetsize(inputFleetSize, bustCache = false, ...trigger) { 
    const spreadsheet = SpreadsheetApp.getActiveSpreadsheet();
    const sheet = spreadsheet.getActiveSheet();
    const sheetFleetSize = spreadsheet.getSheetByName("Fleetsizecoefficients");
    const sheetRiskGroup = spreadsheet.getSheetByName("FeeByRiskGroup");
  
    // ===== Cache setup =====
    const props = PropertiesService.getScriptProperties();
  
    let dataFleetSizecoeff = bustCache ? null : JSON.parse(props.getProperty("fleetSizeCoeff") || "null");
    let dataRiskGroup      = bustCache ? null : JSON.parse(props.getProperty("riskGroup")       || "null");
  
    if (!dataFleetSizecoeff) {
      dataFleetSizecoeff = sheetFleetSize.getRange("A2:D" + sheetFleetSize.getLastRow()).getValues();
      props.setProperty("fleetSizeCoeff", JSON.stringify(dataFleetSizecoeff));
    }
  
    if (!dataRiskGroup) {
      dataRiskGroup = sheetRiskGroup.getRange("A2:F" + sheetRiskGroup.getLastRow()).getValues();
      props.setProperty("riskGroup", JSON.stringify(dataRiskGroup));
    }
  
    // ===== Rating version from state cell F2 =====
    const state = String(sheet.getRange("F2").getValue()).trim().toUpperCase();
    const ratingVersion = (state === "FL") ? 1 : 2;
    Logger.log(`State: ${state} | Rating Version: ${ratingVersion}`);
  
    // ===== Off Rent Endorsement check =====
    const oreValue   = sheet.getRange("F3").getValue();
    const oreApplied = oreValue !== "" && oreValue !== "N/a";
    Logger.log(`ORE Value: "${oreValue}" | ORE Applied: ${oreApplied}`);
  
    // ===== Determine data row count =====
    const lastRow      = sheet.getLastRow();
    const firstDataRow = 16;
    if (lastRow < firstDataRow) {
      Logger.log("No data rows found.");
      return 0;
    }
    const maxRows = lastRow - firstDataRow + 1;
  
    // ===== Batch-read all needed columns =====
    const vinData      = sheet.getRange(`A${firstDataRow}:A${lastRow}`).getValues();
    const dataL        = sheet.getRange(`L${firstDataRow}:L${lastRow}`).getValues(); // Existing Fleet Size Coeff
    const dataO        = sheet.getRange(`O${firstDataRow}:O${lastRow}`).getValues(); // Final Vehicle Risk
    const dataP        = sheet.getRange(`P${firstDataRow}:P${lastRow}`).getValues(); // Deductible
    const dataApproval = sheet.getRange(`G${firstDataRow}:G${lastRow}`).getValues(); // Approval status
  
    // ===== New Fleet Size Coefficient Lookup (version-filtered) =====
    // Table columns: A=Version, B=Min Inclusive, C=Max Exclusive, D=Coefficient
    let newFleetCoeff = 1;
    for (const row of dataFleetSizecoeff) {
      const version = Number(row[0]);
      const min     = Number(row[1]);
      const max     = Number(row[2]);
      const coeff   = Number(row[3]);
  
      if (version === ratingVersion && inputFleetSize >= min && inputFleetSize < max) {
        newFleetCoeff = coeff;
        break;
      }
    }
    Logger.log(`Input Fleet Size: ${inputFleetSize} | Version: ${ratingVersion} | New Fleet Coeff: ${newFleetCoeff}`);
  
    // ===== Risk Group Lookup Map (keyed on deductible only) =====
    // Table columns: A=Deductible, B=Risk Group, C=Min Inclusive, D=Max Exclusive, E=Amount, F=Off Rent Exclusion
    const riskLookup = {};
    for (const row of dataRiskGroup) {
      const deductible = String(row[0]);
      if (!riskLookup[deductible]) riskLookup[deductible] = [];
      riskLookup[deductible].push({
        min:        Number(row[2]),
        max:        Number(row[3]),
        premium:    Number(row[4]),
        premiumORE: isNaN(Number(row[5])) ? Number(row[4]) : Number(row[5])
      });
    }
  
    // ===== Main Loop =====
    const premiumValues = [];
  
    for (let i = 0; i < maxRows; i++) {
      const vin = vinData[i][0];
      if (!vin) continue;
  
      const existingFleetCoeff = Number(dataL[i]?.[0] || 1);
      const finalRiskOriginal  = Number(dataO[i]?.[0] || 0);
  
      // Strip out existing fleet size coeff and substitute the new one
      const coeff_finalrisk = existingFleetCoeff !== 0
        ? (finalRiskOriginal / existingFleetCoeff) * newFleetCoeff
        : 0;
  
      const d          = String(dataP[i]?.[0] || ""); // Deductible from col P
      const isApproved = String(dataApproval[i]?.[0] || "") === "Approved";
  
      // FL: ORE applies to all vehicles when ORE is active
      // Non-FL: ORE only applies to approved vehicles
      const useORE = oreApplied && (state === "FL" || isApproved);
  
      const ranges = riskLookup[d] || [];
      let matched = false;
  
      for (const r of ranges) {
        if (coeff_finalrisk >= r.min && coeff_finalrisk < r.max) {
          const premium = useORE ? r.premiumORE : r.premium;
          premiumValues.push(premium);
          matched = true;
          Logger.log(
            `VIN: ${vin} | OriginalFinalRisk: ${finalRiskOriginal} | ` +
            `OldFleetCoeff: ${existingFleetCoeff} | NewFleetCoeff: ${newFleetCoeff} | ` +
            `AdjustedFinalRisk: ${coeff_finalrisk} | ` +
            `Deductible: ${d} | ORE: ${useORE} | Premium: ${premium}`
          );
          break;
        }
      }
  
      if (!matched) {
        Logger.log(
          `WARNING — No range matched: VIN: ${vin} | Deductible: ${d} | AdjustedFinalRisk: ${coeff_finalrisk}`
        );
      }
    }
  
    // ===== Average Premium =====
    if (premiumValues.length === 0) {
      Logger.log("No premiums calculated — check VIN data, deductibles, and risk ranges.");
      return 0;
    }
  
    const sum            = premiumValues.reduce((acc, val) => acc + val, 0);
    const averagePremium = sum / premiumValues.length;
    Logger.log(`Average Premium: ${averagePremium}`);
    return averagePremium;
  }
  
  function testPremiumFleetSize() {
    const result = premium_fleetsize(5, true);
    Logger.log("Returned Average Premium: " + result);
  }